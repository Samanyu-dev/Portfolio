# Optional: override the public GitHub username used for repository ingestion.
GITHUB_USERNAME=Samanyu-dev

# Optional but recommended on Vercel for higher GitHub API rate limits.
GITHUB_TOKEN=

# Set this to your production URL for canonical metadata and sitemap generation.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Legacy contact-form variables if you decide to revive the EmailJS form flow.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
